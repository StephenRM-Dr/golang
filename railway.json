{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "brailer/Dockerfile",
    "watchPatterns": ["brailer/**"]
  },
  "deploy": {
    "startCommand": "./main",
    "healthcheckPath": "/api/whatsapp/status",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
